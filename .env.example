# Скопируйте этот файл в .env и впишите свой ключ.
#
# Получить БЕСПЛАТНЫЙ ключ Gemini: https://aistudio.google.com/apikey
#   1. Войдите через Google-аккаунт
#   2. "Create API key" → "Create API key in new project"
#   3. Скопируйте ключ — он начинается на AIza...
#
# Никогда не коммитьте .env в git — он уже добавлен в .gitignore.
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
